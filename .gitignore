# ============================================================
#  .gitignore universel pour projets C# / .NET
# ============================================================

# ----- Build & output ----------------------------------------
[Bb]in/
[Oo]bj/
[Oo]ut/
[Ll]og/
[Ll]ogs/
publish/
artifacts/

# ----- Visual Studio -----------------------------------------
.vs/
*.user
*.suo
*.userosscache
*.sln.docstates
*.userprefs

# ----- Rider (JetBrains) -------------------------------------
.idea/
*.sln.iml

# ----- VS Code -----------------------------------------------
.vscode/
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json

# ----- NuGet -------------------------------------------------
*.nupkg
*.snupkg
.nuget/
packages/
!packages/repositories.config
project.lock.json
project.assets.json
*.nuget.props
*.nuget.targets

# ----- .NET / MSBuild ----------------------------------------
*.cache
*.dbmdl
*.jfm
Generated_Code/
_UpgradeReport_Files/
Backup*/
UpgradeLog*.xml
UpgradeLog*.htm

# ----- Fichiers de test & coverage ---------------------------
TestResults/
[Tt]est[Rr]esult*/
*.trx
*.coverage
*.coveragexml
coverage*/
*.opencover.xml

# ----- Entity Framework migrations (facultatif) --------------
# Décommentez si vous ne versionnez pas les migrations auto-générées
# Migrations/

# ----- Secrets & configuration sensible ---------------------
appsettings.Development.json
appsettings.Local.json
appsettings.Secrets.json
secrets.json
*.pfx
*.p12
*.pem
*.key

# ----- Fichiers OS -------------------------------------------
# Windows
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# macOS
.DS_Store
.AppleDouble
.LSOverride
._*

# Linux
*~
.directory

# ----- Docker ------------------------------------------------
# (décommentez si vous ne versionnez pas ces fichiers)
# docker-compose.override.yml

# ----- Azure / Publish profiles ------------------------------
*.pubxml
*.pubxml.user
*.publishproj
PublishScripts/

# ----- Divers ------------------------------------------------
*.tmp
*.temp
*.bak
*.orig
*.rej
.fake/
.paket/
paket-files/
tools/